@incollection{gebser_asynchronous_2023,
  location  = {Cham},
  title     = {Asynchronous Reactive Programming with Modal Types in Haskell},
  volume    = {14512},
  isbn      = {978-3-031-52038-9},
  url       = {https://link.springer.com/10.1007/978-3-031-52038-9_2},
  abstract  = {The implementation of asynchronous systems, in particular graphical user interfaces, is traditionally based on an imperative model that uses shared mutable state and callbacks. While eﬃcient, the combination of shared mutable state and callbacks is notoriously diﬃcult to reason about and prone to errors. Functional reactive programming ({FRP}) provides an elegant alternative and recent theoretical advances in modal {FRP} suggest that it can be eﬃcient as well.},
  pages     = {18--36},
  booktitle = {Practical Aspects of Declarative Languages},
  publisher = {Springer Nature Switzerland},
  author    = {Bahr, Patrick and Houlborg, Emil and Rørdam, Gregers Thomas Skat},
